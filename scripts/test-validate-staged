#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "open3"
require "pathname"
require "tmpdir"

ROOT = Pathname.new(__dir__).join("..").realpath

def capture(*command, chdir:, stdin_data: "")
  Open3.capture3(*command.map(&:to_s), chdir: chdir.to_s, stdin_data: stdin_data)
end

def git(*arguments, chdir:)
  capture("git", *arguments, chdir: chdir)
end

failures = []

Dir.mktmpdir("validate-staged-test") do |dir|
  fixture_root = Pathname.new(dir).join("repo")
  fixture_root.mkpath

  %w[.github .githooks docs scripts skills].each do |entry|
    FileUtils.cp_r(ROOT.join(entry), fixture_root.join(entry))
  end
  %w[AGENTS.md CHANGELOG.md README.md].each do |entry|
    FileUtils.cp(ROOT.join(entry), fixture_root.join(entry))
  end

  _stdout, stderr, status = git("init", "--quiet", "--initial-branch=main", fixture_root, chdir: dir)
  raise "git fixture setup failed: #{stderr.strip}" unless status.success?

  git("config", "user.name", "Fixture User", chdir: fixture_root)
  git("config", "user.email", "fixture@example.com", chdir: fixture_root)
  git("add", ".", chdir: fixture_root)
  _stdout, stderr, status = git(
    "commit",
    "--quiet",
    "--no-verify",
    "-m",
    "test: create staged-validation fixture",
    chdir: fixture_root
  )
  raise "fixture baseline commit failed: #{stderr.strip}" unless status.success?

  readme = fixture_root.join("README.md")
  File.open(readme, "a") { |file| file.write("\nFixture staged change.\n") }
  git("add", "README.md", chdir: fixture_root)

  resume = fixture_root.join("skills/resume/SKILL.md")
  resume.write(resume.read.sub("name: resume", "name: wrong-name"))

  validator = fixture_root.join("scripts/validate-staged")
  hook = fixture_root.join(".githooks/pre-commit")

  stdout, stderr, status = capture(validator, chdir: fixture_root)
  unless status.success? && stdout.include?("validate-staged: ok")
    failures << "unstaged changes affected validation: stdout=#{stdout.inspect}, stderr=#{stderr.inspect}"
  end

  stdout, stderr, status = capture(hook, chdir: fixture_root)
  unless status.success? && stdout.include?("validate-staged: ok")
    failures << "pre-commit hook failed: stdout=#{stdout.inspect}, stderr=#{stderr.inspect}"
  end

  git("add", "skills/resume/SKILL.md", chdir: fixture_root)
  _stdout, stderr, status = capture(validator, chdir: fixture_root)
  unless !status.success? && stderr.include?("must match folder")
    failures << "invalid staged skill was accepted: stderr=#{stderr.inspect}"
  end

  git("reset", "--quiet", "HEAD", chdir: fixture_root)
  File.open(readme, "a") { |file| file.write("trailing whitespace  \n") }
  git("add", "README.md", chdir: fixture_root)
  stdout, stderr, status = capture(validator, chdir: fixture_root)
  combined_output = "#{stdout}\n#{stderr}"
  unless !status.success? && combined_output.include?("trailing whitespace")
    failures << "staged whitespace error was accepted: output=#{combined_output.inspect}"
  end
end

if failures.empty?
  puts "test-validate-staged: ok"
else
  warn "test-validate-staged failed:"
  failures.each { |failure| warn "- #{failure}" }
  exit 1
end
